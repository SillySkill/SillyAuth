# Flask配置
FLASK_ENV=development
FLASK_DEBUG=1

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=jc_ai_activity
DB_USER=jcode
DB_PASSWORD=your_password

# ==================== 后台管理系统新增配置 ====================

# 数据库类型和异步连接字符串
DB_TYPE=postgresql
# PostgreSQL异步连接
DATABASE_URL=postgresql+asyncpg://username:password@host:port/database
# MySQL异步连接（可选）
# DATABASE_URL_MYSQL=mysql+aiomysql://username:password@host:port/database

# JWT配置
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION_HOURS=24

# 阿里云OSS配置（后台管理用）
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
OSS_BUCKET_NAME=your-bucket-name

# 原有OSS配置（保持兼容）
ALIYUN_ACCESS_KEY=your_access_key
ALIYUN_ACCESS_SECRET=your_access_secret
ALIYUN_BUCKET=jc-hot
ALIYUN_ENDPOINT=oss-cn-shanghai.aliyuncs.com

# 火山引擎配置
VOLCANO_API_KEY=your_api_key
VOLCANO_ENDPOINT=your_endpoint

# 配置存储路径
CONFIG_STORAGE_PATH=./config_storage
CONFIG_BACKUP_PATH=./config_backup
