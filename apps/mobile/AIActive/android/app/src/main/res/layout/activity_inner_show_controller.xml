<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- 顶部状态栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@android:color/white"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="连接状态"
                android:textSize="12sp"
                android:textColor="@color/textSecondary" />

            <TextView
                android:id="@+id/tv_connection_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="已连接"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/color_success" />

        </LinearLayout>

        <Button
            android:id="@+id/btn_disconnect"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="断开连接"
            android:textSize="12sp"
            android:background="@drawable/btn_outline_danger"
            android:textColor="@color/color_error"
            android:minWidth="0dp"
            android:paddingLeft="16dp"
            android:paddingRight="16dp" />

    </LinearLayout>

    <!-- 主控制区 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 播放状态卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@drawable/bg_card"
                android:elevation="2dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="播放状态"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:layout_marginBottom="16dp" />

                <!-- 状态信息 -->
                <TextView
                    android:id="@+id/tv_playback_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="播放中"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tv_current_program"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="当前节目: 欢迎各位来宾"
                    android:textSize="16sp"
                    android:textColor="@color/textPrimary"
                    android:layout_marginBottom="16dp" />

                <!-- 进度条 -->
                <TextView
                    android:id="@+id/tv_progress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="30s / 300s"
                    android:textSize="14sp"
                    android:textColor="@color/textSecondary"
                    android:layout_marginBottom="8dp" />

                <SeekBar
                    android:id="@+id/seek_bar_progress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="300"
                    android:progress="30" />

            </LinearLayout>

            <!-- 播放控制卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@drawable/bg_card"
                android:elevation="2dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="播放控制"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:layout_marginBottom="16dp" />

                <!-- 控制按钮 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <!-- 上一曲 -->
                    <Button
                        android:id="@+id/btn_previous"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/btn_circle_secondary"
                        android:src="@drawable/ic_skip_previous"
                        android:layout_marginEnd="16dp" />

                    <!-- 停止 -->
                    <Button
                        android:id="@+id/btn_stop"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="@drawable/btn_circle_danger"
                        android:src="@drawable/ic_stop"
                        android:layout_marginEnd="16dp" />

                    <!-- 播放/暂停 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginEnd="16dp">

                        <Button
                            android:id="@+id/btn_play"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:background="@drawable/btn_circle_primary"
                            android:src="@drawable/ic_play" />

                        <Button
                            android:id="@+id/btn_pause"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:background="@drawable/btn_circle_warning"
                            android:src="@drawable/ic_pause"
                            android:visibility="gone" />

                    </LinearLayout>

                    <!-- 下一曲 -->
                    <Button
                        android:id="@+id/btn_next"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/btn_circle_secondary"
                        android:src="@drawable/ic_skip_next" />

                </LinearLayout>

            </LinearLayout>

            <!-- 操作日志 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@drawable/bg_card"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="操作日志"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:layout_marginBottom="12dp" />

                <ScrollView
                    android:id="@+id/log_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:background="@color/backgroundLight"
                    android:padding="8dp">

                    <TextView
                        android:id="@+id/tv_log"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/textPrimary"
                        android:fontFamily="monospace" />

                </ScrollView>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
