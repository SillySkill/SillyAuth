<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/iv_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="背景" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#80000000">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:orientation="horizontal"
            android:padding="8dp"
            tools:visibility="gone">

            <Button
                android:id="@+id/btn_back"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/back"
                android:textColor="@color/text_on_primary" />

            <TextView
                android:id="@+id/tv_program_name"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:gravity="center"
                android:text="抽奖程序"
                android:textColor="@color/text_on_primary"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tv_offline_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/offline_bg"
                android:padding="4dp"
                android:text="@string/offline_mode"
                android:textColor="@color/offline_text"
                android:visibility="gone" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_remaining_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="0dp"
            android:text="剩余：20/20"
            android:textAlignment="center"
            android:textSize="16sp"
            tools:visibility="gone" />

        <TextView
            android:id="@+id/tv_mode_indicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/mode_random"
            android:padding="8dp"
            android:text="🎲 随机模式"
            android:textAlignment="center"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_target_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👤 标的对象：人"
            android:textSize="14sp"
            android:textAlignment="center"
            android:padding="6dp"
            android:background="#E0E0E0"
            android:textColor="@color/text_primary"
            android:visibility="visible" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="32dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_rolling_text"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/lottery_rolling_background"
                android:gravity="center"
                android:text="准备抽奖"
                android:textSize="24sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btn_start"
                    android:layout_width="100dp"
                    android:layout_height="45dp"
                    android:text="@string/start_lottery"
                    android:textSize="16sp"
                    android:layout_marginEnd="12dp" />

                <Button
                    android:id="@+id/btn_stop"
                    android:layout_width="100dp"
                    android:layout_height="45dp"
                    android:text="@string/stop_lottery"
                    android:textSize="16sp"
                    android:enabled="false" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="12dp">

                <Button
                    android:id="@+id/btn_reset"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="重置抽奖"
                    android:textSize="14sp"
                    android:layout_marginEnd="12dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <Button
                    android:id="@+id/btn_return_pool"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="回退奖池"
                    android:textSize="14sp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            </LinearLayout>

            <Button
                android:id="@+id/btn_voice_control"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎤 语音控制"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@color/background"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_winner_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="中奖名单：\n"
                android:textSize="16sp" />

        </ScrollView>

    </LinearLayout>

    <!-- 数字人显示区域（左下角） -->
    <FrameLayout
        android:id="@+id/digital_human_container"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:layout_margin="16dp"
        android:background="@android:color/transparent"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_digital_human"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:contentDescription="数字人" />
    </FrameLayout>

</RelativeLayout>
