<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <TextView
            android:id="@+id/tv_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="得分：80 分"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/tv_result"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="优秀！"
            android:textSize="28sp"
            android:textColor="#000000"
            android:layout_marginBottom="24dp" />

        <!-- 奖品卡片 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_prize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:visibility="gone"
            android:elevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <!-- 奖品图片 -->
                <ImageView
                    android:id="@+id/iv_prize_image"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp" />

                <!-- 奖品等级 -->
                <TextView
                    android:id="@+id/tv_prize_level"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎉 一等奖"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_marginBottom="12dp" />

                <!-- 奖品名称 -->
                <TextView
                    android:id="@+id/tv_prize_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="精美礼品一份"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_marginBottom="12dp" />

                <!-- 奖品描述 -->
                <TextView
                    android:id="@+id/tv_prize_description"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="答对8题以上，获得纪念品一份"
                    android:textSize="16sp"
                    android:textColor="#333333"
                    android:gravity="center"
                    android:layout_marginBottom="16dp" />

                <!-- 中奖提示 -->
                <TextView
                    android:id="@+id/tv_prize_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="恭喜您中奖啦！请截图保存或前往领奖处领取。"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:gravity="center" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 无奖品提示 -->
        <TextView
            android:id="@+id/tv_no_prize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="恭喜完成答题！"
            android:textSize="18sp"
            android:textColor="#000000"
            android:layout_marginBottom="48dp" />

        <Button
            android:id="@+id/btn_share"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="分享成绩"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/back"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    </LinearLayout>

</ScrollView>
