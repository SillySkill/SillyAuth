<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Title Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#2196F3"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <Button
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="←"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="3D球体抽奖设置"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:gravity="center" />

        <View
            android:layout_width="48dp"
            android:layout_height="48dp" />

    </LinearLayout>

    <!-- Settings Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Participants Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="参与人员设置"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/tv_participant_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="当前人数：0人"
                android:textSize="14sp"
                android:textColor="#666666"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="16dp">

                <Button
                    android:id="@+id/btn_import_participants"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="导入人员"
                    android:layout_marginEnd="8dp"
                    android:background="#2196F3"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/btn_clear_participants"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="清空"
                    android:layout_marginStart="8dp"
                    android:background="#F44336"
                    android:textColor="#FFFFFF" />

            </LinearLayout>

            <!-- Prizes Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="奖品设置"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_prizes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="16dp" />

            <Button
                android:id="@+id/btn_add_prize"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="+ 添加奖品"
                android:background="#4CAF50"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="16dp" />

            <!-- Visual Settings Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="视觉设置"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="球体旋转速度"
                    android:textSize="16sp"
                    android:textColor="#333333" />

                <SeekBar
                    android:id="@+id/seekbar_rotation_speed"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:max="100"
                    android:progress="30" />

                <TextView
                    android:id="@+id/tv_rotation_speed"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="30%"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:gravity="end" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="卡片大小"
                    android:textSize="16sp"
                    android:textColor="#333333" />

                <SeekBar
                    android:id="@+id/seekbar_card_size"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:max="100"
                    android:progress="50" />

                <TextView
                    android:id="@+id/tv_card_size"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="50%"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:gravity="end" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="卡片背景色"
                    android:textSize="16sp"
                    android:textColor="#333333" />

                <Button
                    android:id="@+id/btn_card_color"
                    android:layout_width="120dp"
                    android:layout_height="40dp"
                    android:text="选择颜色"
                    android:background="#FF6B9D"
                    android:textColor="#FFFFFF" />

            </LinearLayout>

            <!-- Audio Settings Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="音频设置"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="背景音乐"
                        android:textSize="16sp"
                        android:textColor="#333333" />

                    <ToggleButton
                        android:id="@+id/toggle_bg_music"
                        android:layout_width="60dp"
                        android:layout_height="36dp"
                        android:textOn="开"
                        android:textOff="关"
                        android:background="#2196F3"
                        android:textColor="#FFFFFF" />

                </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="音效"
                    android:textSize="16sp"
                    android:textColor="#333333" />

                <ToggleButton
                    android:id="@+id/toggle_sound_effects"
                    android:layout_width="60dp"
                    android:layout_height="36dp"
                    android:textOn="开"
                    android:textOff="关"
                    android:background="#2196F3"
                    android:textColor="#FFFFFF" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="音量"
                    android:textSize="16sp"
                    android:textColor="#333333" />

                <SeekBar
                    android:id="@+id/seekbar_volume"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:max="100"
                    android:progress="70" />

                <TextView
                    android:id="@+id/tv_volume"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="70%"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:gravity="end" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Save Button -->
    <Button
        android:id="@+id/btn_save"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="保存设置"
        android:textSize="18sp"
        android:background="#4CAF50"
        android:textColor="#FFFFFF"
        android:layout_margin="16dp" />

</LinearLayout>
