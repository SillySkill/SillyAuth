<?xml version="1.0" encoding="utf-8"?>
<!-- 媒体上传对话框 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="上传媒体文件"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/textPrimary"
        android:layout_marginBottom="16dp" />

    <!-- 媒体名称 -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="媒体名称"
        android:layout_marginBottom="12dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- 适用模块 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="适用模块"
        android:textSize="14sp"
        android:textColor="@color/textSecondary"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:id="@+id/ll_module"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <CheckBox
            android:id="@+id/cb_warmup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="暖场秀"
            android:checked="true" />

        <CheckBox
            android:id="@+id/cb_hosting"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="主持秀" />

        <CheckBox
            android:id="@+id/cb_teabreak"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="茶歇秀" />

    </LinearLayout>

    <!-- 手动输入模块 -->
    <EditText
        android:id="@+id/et_module"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="手动输入模块ID"
        android:visibility="gone"
        android:layout_marginBottom="12dp" />

    <!-- 媒体类型 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="媒体类型"
        android:textSize="14sp"
        android:textColor="@color/textSecondary"
        android:layout_marginBottom="4dp" />

    <RadioGroup
        android:id="@+id/rg_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <RadioButton
            android:id="@+id/rb_background"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="背景图片"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rb_music"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="背景音乐" />

        <RadioButton
            android:id="@+id/rb_sticker"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="贴纸" />

    </RadioGroup>

    <!-- 手动输入类型 -->
    <LinearLayout
        android:id="@+id/ll_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginBottom="12dp">

        <EditText
            android:id="@+id/et_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="手动输入媒体类型" />

    </LinearLayout>

    <!-- 选择文件 -->
    <Button
        android:id="@+id/btn_select_file"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="选择文件"
        android:textSize="14sp"
        android:background="@drawable/btn_outline_secondary"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_file_path"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="未选择文件"
        android:textSize="12sp"
        android:textColor="@color/textSecondary"
        android:padding="8dp"
        android:background="@color/backgroundLight"
        android:layout_marginBottom="12dp" />

    <!-- 进度条 -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        style="?android:attr/progressBarStyleHorizontal"
        android:indeterminateOnly="true" />

</LinearLayout>
