<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- 顶部栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/primary">

        <Button
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/back"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:textColor="@color/text_on_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="请签名"
            android:textSize="20sp"
            android:textColor="@color/text_on_primary"
            android:gravity="center"
            android:layout_gravity="center_vertical" />

        <Button
            android:id="@+id/btn_toggle_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="切换到文字签名"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:textColor="@color/text_on_primary" />

    </LinearLayout>

    <!-- 提示信息 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="请在下方区域签名，您的签名将与AI生成图片一同展示到内场大屏"
        android:textSize="14sp"
        android:padding="16dp"
        android:gravity="center"
        android:textColor="@color/text_secondary" />

    <!-- 手写签名区域 -->
    <com.jcoding.aiactivity.ui.SignatureActivity.SignatureView
        android:id="@+id/signature_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="16dp"
        android:background="@color/white" />

    <!-- 文字签名输入 -->
    <EditText
        android:id="@+id/et_text_signature"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="请输入您的姓名作为签名"
        android:textSize="18sp"
        android:padding="16dp"
        android:layout_margin="16dp"
        android:background="@color/white"
        android:visibility="gone"
        android:maxLines="1" />

    <!-- 操作按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <Button
            android:id="@+id/btn_clear"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:text="清除"
            android:layout_marginEnd="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <Button
            android:id="@+id/btn_confirm"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:text="确认签名"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</LinearLayout>
