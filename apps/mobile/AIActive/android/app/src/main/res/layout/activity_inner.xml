<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- 背景图/视频 -->
    <ImageView
        android:id="@+id/iv_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.3"
        android:src="@android:drawable/screen_background_light" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 顶部控制栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="#80000000">

            <Button
                android:id="@+id/btn_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/back"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/inner_show_title"
                android:textSize="20sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_gravity="center_vertical" />

            <Button
                android:id="@+id/btn_toggle_auto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▶ 开始轮播"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textColor="@color/white" />

        </LinearLayout>

        <!-- 主内容区域 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="16dp">

            <!-- 内容图片（AI生成结果+签名） -->
            <ImageView
                android:id="@+id/iv_content"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:layout_centerInParent="true" />

            <!-- 签名文字（叠加在图片上） -->
            <TextView
                android:id="@+id/tv_signature"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="36sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:shadowColor="#AA000000"
                android:shadowDx="4"
                android:shadowDy="4"
                android:shadowRadius="8"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"
                android:layout_marginBottom="100dp"
                android:visibility="gone" />

        </RelativeLayout>

        <!-- 信息栏 -->
        <TextView
            android:id="@+id/tv_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI生成: 0张  |  签到: 0人  |  当前: 0/0"
            android:textSize="18sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:padding="12dp"
            android:background="#80000000" />

        <!-- 控制按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="#80000000">

            <Button
                android:id="@+id/btn_prev"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="◀ 上一张"
                android:textSize="20sp"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/btn_next"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="下一张 ▶"
                android:textSize="20sp"
                android:layout_marginStart="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="@color/white" />

        </LinearLayout>

    </LinearLayout>

    <!-- 数字人显示区域（左下角） -->
    <FrameLayout
        android:id="@+id/digital_human_container"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_gravity="bottom|start"
        android:layout_margin="16dp"
        android:background="@android:color/transparent"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_digital_human"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:contentDescription="数字人" />
    </FrameLayout>

</FrameLayout>
