<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 相机预览视图 -->
    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:scaleType="fillCenter" />

    <!-- 前遮盖图：styleBk.png (放在预览视图之后，确保在其他视图之下，不拦截触摸事件) -->
    <ImageView
        android:id="@+id/iv_refer_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:adjustViewBounds="false"
        android:alpha="0.6"
        android:visibility="visible"
        android:clickable="false"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:contentDescription="前遮盖图" />

    <!-- 拍好的照片 -->
    <ImageView
        android:id="@+id/iv_captured"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true"
        android:visibility="gone" />

    <!-- 倒计时显示 -->
    <TextView
        android:id="@+id/tv_countdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="20"
        android:textSize="120sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:shadowColor="#000000"
        android:shadowDx="4"
        android:shadowDy="4"
        android:shadowRadius="8"
        android:visibility="gone" />

    <!-- 顶部栏：返回按钮和离线模式提示 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_offline_mode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/offline_mode"
            android:textColor="@color/offline_text"
            android:background="@color/offline_bg"
            android:padding="8dp"
            android:gravity="center"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/back"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

    </LinearLayout>

    <!-- 拍照按钮容器 - 屏幕正中间 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:elevation="20dp">

        <!-- 拍照按钮 -->
        <Button
            android:id="@+id/btn_capture"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/capture_button_background"
            android:clickable="true"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:alpha="0.7" />

    </LinearLayout>

    <!-- 重拍和确认按钮容器 - 屏幕中央显示 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:id="@+id/layout_confirm_buttons">

        <!-- 重拍按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_retake"
            android:layout_width="200dp"
            android:layout_height="60dp"
            android:text="重拍"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp"
            app:cornerRadius="30dp"
            app:backgroundTint="#FF6B6B"
            style="@style/Widget.MaterialComponents.Button" />

        <!-- 确认按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_confirm"
            android:layout_width="200dp"
            android:layout_height="60dp"
            android:text="确认"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:cornerRadius="30dp"
            app:backgroundTint="#4ECDC4"
            style="@style/Widget.MaterialComponents.Button" />

    </LinearLayout>

</FrameLayout>
