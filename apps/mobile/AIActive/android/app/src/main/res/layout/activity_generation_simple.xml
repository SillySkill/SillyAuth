<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- 上传的照片 + 遮罩层 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center">

        <!-- 上传的照片（背景层） -->
        <ImageView
            android:id="@+id/iv_uploaded_photo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="#222222"
            android:contentDescription="上传的照片" />

        <!-- 遮罩层图片（前景层，半透明） -->
        <ImageView
            android:id="@+id/iv_mask_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:alpha="0.6"
            android:contentDescription="遮罩层" />

    </FrameLayout>

    <!-- 顶部状态栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← 返回"
            android:textColor="#FFFFFF"
            android:background="@android:color/transparent"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

        <TextView
            android:id="@+id/tv_offline_mode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/offline_mode"
            android:textColor="@color/offline_text"
            android:background="@color/offline_bg"
            android:padding="8dp"
            android:gravity="center"
            android:visibility="gone" />

    </LinearLayout>

    <!-- 中央状态信息 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <!-- 状态文字 -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="正在准备..."
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:shadowColor="#AA000000"
            android:shadowDx="4"
            android:shadowDy="4"
            android:shadowRadius="8"
            android:layout_marginBottom="16dp"
            android:gravity="center" />

        <!-- 进度条 -->
        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:visibility="visible" />

        <!-- 进度百分比 -->
        <TextView
            android:id="@+id/tv_progress_percentage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textSize="24sp"
            android:textColor="#4ECDC4"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <!-- 预计时间 -->
        <TextView
            android:id="@+id/tv_eta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="预计剩余: --"
            android:textSize="16sp"
            android:textColor="#CCCCCC"
            android:visibility="gone" />

    </LinearLayout>

    <!-- 数字人显示区域（左下角） -->
    <FrameLayout
        android:id="@+id/digital_human_container"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="bottom|start"
        android:layout_margin="16dp"
        android:background="@android:color/transparent"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_digital_human"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:contentDescription="数字人" />
    </FrameLayout>

</FrameLayout>
