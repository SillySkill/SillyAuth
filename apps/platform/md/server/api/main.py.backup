@app.get("/api/skills", response_model=List[SkillListResponse])
async def get_skills(
    category: Optional[str] = None,
    type: Optional[str] = None,
    status: str = "approved",
    is_featured: Optional[bool] = None,
    limit: int = 50,
    offset: int = 0
):
    """
    获取 Skills 列表

    参数:
    - category: 分类筛选
    - type: 类型筛选 (free/commercial)
    - status: 状态筛选
    - is_featured: 是否精选
    - limit: 返回数量
    - offset: 偏移量
    """
    try:
        with get_db(DB_CONFIG) as conn:
            with conn.cursor(cursor_factory=RealDictCursor) as cur:
                # 构建查询
                query = """
                    SELECT
                        s.id,
                        s.skill_id,
                        s.name,
                        s.description,
                        s.category,
                        s.type,
                        s.version,
                        s.status,
                        s.price,
                        s.is_featured,
                        s.view_count,
                        s.download_count,
                        s.favorite_count,
                        s.rating_avg,
                        s.rating_count,
                        s.published_at,
                        u.username as author_username,
                        u.avatar_url as author_avatar,
                        u.vendor_level as author_level,
                        u.bio as author_bio
                    FROM skills s
                    LEFT JOIN users u ON s.author_id = u.id
                    WHERE s.status = %s
                      AND s.is_deleted = FALSE
                """
                params = [status]

                if category:
                    query += " AND s.category = %s"
                    params.append(category)

                if type:
                    query += " AND s.type = %s"
                    params.append(type)

                if is_featured is not None:
                    query += " AND s.is_featured = %s"
                    params.append(is_featured)

                query += " ORDER BY s.published_at DESC, s.created_at DESC LIMIT %s OFFSET %s"
                params.extend([limit, offset])

                cur.execute(query, params)

                rows = cur.fetchall()

                results = []
                for row in rows:
                    results.append(SkillListResponse(**row))

                return results
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.get("/api/skills/{skill_id}", response_model=SkillDetail)
async def get_skill_detail(skill_id: str):
    """获取 Skill 详情"""
    try:
        with get_db(DB_CONFIG) as conn:
            with conn.cursor(cursor_factory=RealDictCursor) as cur:
                query = """
                    SELECT
                        s.*,
                        u.username as author_username,
                        u.email as author_email,
                        u.avatar_url as author_avatar,
                        u.vendor_level as author_level,
                        u.bio as author_bio
                    FROM skills s
                    LEFT JOIN users u ON s.author_id = u.id
                    WHERE s.skill_id = %s
                """

                cur.execute(query, (skill_id,))
                row = cur.fetchone()

                if not row:
                    raise HTTPException(status_code=404, detail="Skill not found")

                return SkillDetail(**row)
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.get("/api/users", response_model=List[UserListResponse])
async def get_users(
    role: Optional[str] = None,
    vendor_level: Optional[str] = None,
    limit: int = 50,
    offset: int = 0
):
    """获取用户列表"""
    try:
        with get_db(DB_CONFIG) as conn:
            with conn.cursor(cursor_factory=RealDictCursor) as cur:
                query = """
                    SELECT
                        u.id,
                        u.username,
                        u.email,
                        u.avatar_url,
                        u.bio,
                        u.role,
                        u.vendor_level,
                        u.created_at,
                        (SELECT COUNT(*) FROM skills s WHERE s.author_id = u.id AND s.is_deleted = FALSE) as skill_count
                    FROM users u
                    WHERE u.is_active = TRUE
                      AND u.email NOT LIKE '%%@seed.local'
                """
                params = []

                if role:
                    query += " AND u.role = %s"
                    params.append(role)

                if vendor_level:
                    query += " AND u.vendor_level = %s"
                    params.append(vendor_level)

                query += " ORDER BY u.created_at DESC LIMIT %s OFFSET %s"
                params.extend([limit, offset])

                cur.execute(query, params)
                rows = cur.fetchall()

                results = []
                for row in rows:
                    results.append(UserListResponse(**row))

                return results
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.get("/api/users/{username}", response_model=UserDetail)
async def get_user_detail(username: str):
    """获取用户详情"""
    try:
        with get_db(DB_CONFIG) as conn:
            with conn.cursor(cursor_factory=RealDictCursor) as cur:
                query = """
                    SELECT
                        u.id,
                        u.username,
                        u.email,
                        u.avatar_url,
                        u.bio,
                        u.role,
                        u.vendor_level,
                        u.ai_points,
                        u.preferred_language,
                        u.theme_preference,
                        u.is_active,
                        u.is_verified,
                        u.created_at,
                        u.updated_at,
                        (SELECT COUNT(*) FROM skills s WHERE s.author_id = u.id AND s.is_deleted = FALSE) as skill_count,
                        (SELECT COALESCE(SUM(s.download_count), 0) FROM skills s WHERE s.author_id = u.id AND s.is_deleted = FALSE) as total_downloads,
                        (SELECT COALESCE(AVG(s.rating_avg), 0) FROM skills s WHERE s.author_id = u.id AND s.is_deleted = FALSE AND s.rating_avg > 0) as avg_rating
                    FROM users u
                    WHERE u.username = %s
                      AND u.email NOT LIKE '%%@seed.local'
                """

                cur.execute(query, (username,))
                row = cur.fetchone()

                if not row:
                    raise HTTPException(status_code=404, detail="User not found")

                return UserDetail(**row)
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.get("/api/teams", response_model=List[TeamListResponse])
async def get_teams(limit: int = 50, offset: int = 0):
    """获取团队列表"""
    try:
        with get_db(DB_CONFIG) as conn:
            with conn.cursor(cursor_factory=RealDictCursor) as cur:
                query = """
                    SELECT
                        t.id,
                        t.team_name,
                        t.team_slug,
                        t.description,
                        t.avatar_url,
                        t.member_count,
                        t.created_at,
                        u.username as owner_username,
                        (SELECT COUNT(*) FROM team_projects p WHERE p.team_id = t.id) as project_count
                    FROM teams t
                    LEFT JOIN users u ON t.owner_id = u.id
                    WHERE t.is_active = TRUE
                    ORDER BY t.created_at DESC
                    LIMIT %s OFFSET %s
                """

                cur.execute(query, (limit, offset))
                rows = cur.fetchall()

                results = []
                for row in rows:
                    results.append(TeamListResponse(**row))

                return results
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.get("/api/market/stats", response_model=MarketStats)
async def get_market_stats():
    """获取市场统计数据"""
    try:
        with get_db(DB_CONFIG) as conn:
            with conn.cursor(cursor_factory=RealDictCursor) as cur:
                # 总用户数（不含种子用户）
                cur.execute("""
                    SELECT COUNT(*) as count FROM users
                    WHERE is_active = TRUE AND email NOT LIKE '%%@seed.local'
                """)
                total_users = cur.fetchone()['count']

                # 总 Skills 数（不含种子）
                cur.execute("""
                    SELECT COUNT(*) as count FROM skills
                    WHERE is_deleted = FALSE AND skill_id NOT LIKE 'seed_%%'
                """)
                total_skills = cur.fetchone()['count']

                # 供应商数
                cur.execute("""
                    SELECT COUNT(*) as count FROM users
                    WHERE role = 'vendor' AND is_active = TRUE AND email NOT LIKE '%%@seed.local'
                """)
                total_vendors = cur.fetchone()['count']

                # 免费 Skills
                cur.execute("""
                    SELECT COUNT(*) as count FROM skills
                    WHERE type = 'free' AND is_deleted = FALSE AND skill_id NOT LIKE 'seed_%'
                """)
                free_skills = cur.fetchone()['count']

                # 付费 Skills
                cur.execute("""
                    SELECT COUNT(*) as count FROM skills
                    WHERE type = 'commercial' AND is_deleted = FALSE AND skill_id NOT LIKE 'seed_%'
                """)
                paid_skills = cur.fetchone()['count']

                # 团队数
                cur.execute("SELECT COUNT(*) as count FROM teams WHERE is_active = TRUE")
                total_teams = cur.fetchone()['count']

                return MarketStats(
                    total_users=total_users,
                    total_skills=total_skills,
                    total_vendors=total_vendors,
                    free_skills=free_skills,
                    paid_skills=paid_skills,
                    total_teams=total_teams
                )
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


