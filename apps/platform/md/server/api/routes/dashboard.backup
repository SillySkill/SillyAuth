"""
Dashboard API Routes
仪表盘 API 路由

提供用户仪表板数据、统计信息、最近活动等
"""
from fastapi import APIRouter, Depends, Query
from typing import Optional, List, Dict, Any
from datetime import datetime, timedelta
from pydantic import BaseModel
import logging

from database import get_db
from psycopg2.extras import RealDictCursor

logger = logging.getLogger(__name__)

router = APIRouter(prefix="/api/dashboard", tags=["仪表盘"])

# DB配置需要在调用时传入
DB_CONFIG = None


def set_db_config(config):
    """设置数据库配置"""
    global DB_CONFIG
    DB_CONFIG = config


# ============================================
# Response Models
# ============================================

class DashboardStats(BaseModel):
    """仪表板统计数据"""
    totalViews: int
    totalUsers: int
    totalSkills: int
    conversionRate: float
    revenue: float
    viewsChange: float
    usersChange: float
    conversionChange: float
    revenueChange: float


class ActivityItem(BaseModel):
    """活动项"""
    id: int
    action: str
    username: Optional[str] = None
    description: str
    timestamp: datetime
    icon: str


class QuickAction(BaseModel):
    """快速操作"""
    name: str
    icon: str
    url: str
    description: str


# ============================================
# Dashboard API Endpoints
# ============================================

@router.get("/stats", response_model=Dict[str, Any])
async def get_dashboard_stats(
    days: int = Query(7, description="统计天数", ge=1, le=90),
    language: str = Query("zh", description="语言")
):
    """
    获取仪表板统计数据

    返回访问量、用户数、转化率等核心指标
    """
    try:
        with get_db(DB_CONFIG) as conn:
            with conn.cursor(cursor_factory=RealDictCursor) as cur:
                # 计算时间范围
                current_period_start = datetime.now() - timedelta(days=days)
                previous_period_start = current_period_start - timedelta(days=days)

                # 当前期间统计
                cur.execute("""
                    SELECT
                        COUNT(DISTINCT user_id) as total_users,
                        COUNT(*) as total_views
                    FROM user_activity_logs
                    WHERE created_at >= %s
                """, (current_period_start,))
                current_stats = cur.fetchone()

                # 上一期间统计
                cur.execute("""
                    SELECT
                        COUNT(DISTINCT user_id) as total_users,
                        COUNT(*) as total_views
                    FROM user_activity_logs
                    WHERE created_at >= %s AND created_at < %s
                """, (previous_period_start, current_period_start))
                previous_stats = cur.fetchone()

                # 总Skills数
                cur.execute("""
                    SELECT COUNT(*) as count
                    FROM skills
                    WHERE is_deleted = FALSE
                      AND skill_id NOT LIKE 'seed_%%'
                """)
                total_skills = cur.fetchone()['count']

                # 模拟转化率和收入数据（实际应该从订单表计算）
                conversion_rate = 68.2
                revenue = 12345.0

                # 计算变化率
                views_change = 0
                users_change = 0

                if previous_stats['total_views'] > 0:
                    views_change = ((current_stats['total_views'] - previous_stats['total_views']) / previous_stats['total_views']) * 100

                if previous_stats['total_users'] > 0:
                    users_change = ((current_stats['total_users'] - previous_stats['total_users']) / previous_stats['total_users']) * 100

                return {
                    "success": True,
                    "data": {
                        "totalViews": current_stats['total_views'] or 0,
                        "totalUsers": current_stats['total_users'] or 0,
                        "totalSkills": total_skills,
                        "conversionRate": conversion_rate,
                        "revenue": revenue,
                        "viewsChange": round(views_change, 1),
                        "usersChange": round(users_change, 1),
                        "conversionChange": 5.1,
                        "revenueChange": -2.3
                    }
                }
    except Exception as e:
        logger.error(f"获取仪表板统计失败: {str(e)}")
        return {
            "success": False,
            "message": f"获取仪表板统计失败: {str(e)}"
        }


@router.get("/recent-activity", response_model=Dict[str, Any])
async def get_recent_activity(
    limit: int = Query(10, description="返回数量", ge=1, le=50)
):
    """
    获取最近活动列表

    返回用户登录、内容创建等最近活动
    """
    try:
        with get_db(DB_CONFIG) as conn:
            with conn.cursor(cursor_factory=RealDictCursor) as cur:
                cur.execute("""
                    SELECT
                        al.id,
                        al.action,
                        al.entity,
                        al.entity_id,
                        al.details,
                        al.created_at,
                        u.username,
                        u.avatar_url
                    FROM user_activity_logs al
                    LEFT JOIN users u ON al.user_id = u.id
                    ORDER BY al.created_at DESC
                    LIMIT %s
                """, (limit,))

                activities = cur.fetchall()

                # 格式化活动数据
                formatted_activities = []
                for activity in activities:
                    # 根据action类型确定图标和描述
                    icon_map = {
                        'LOGIN': 'fa-sign-in-alt',
                        'LOGOUT': 'fa-sign-out-alt',
                        'CREATE_SKILL': 'fa-file-alt',
                        'UPDATE_SKILL': 'fa-edit',
                        'DELETE_SKILL': 'fa-trash',
                        'REGISTER': 'fa-user-plus',
                        'COMMENT': 'fa-comment',
                        'DOWNLOAD': 'fa-download',
                        'FAVORITE': 'fa-heart'
                    }

                    icon = icon_map.get(activity['action'], 'fa-circle')

                    # 构建描述
                    description = f"{activity.get('username', '未知用户')} 执行了 {activity['action']} 操作"

                    formatted_activities.append({
                        "id": activity['id'],
                        "action": activity['action'],
                        "username": activity.get('username'),
                        "description": description,
                        "timestamp": activity['created_at'].isoformat() if activity['created_at'] else None,
                        "icon": icon
                    })

                return {
                    "success": True,
                    "data": formatted_activities
                }
    except Exception as e:
        logger.error(f"获取最近活动失败: {str(e)}")
        return {
            "success": False,
            "message": f"获取最近活动失败: {str(e)}",
            "data": []
        }


