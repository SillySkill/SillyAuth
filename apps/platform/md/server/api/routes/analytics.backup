"""
Analytics API Routes
数据分析 API 路由

提供访问统计、页面浏览量、用户行为分析等
"""
from fastapi import APIRouter, Query
from typing import Dict, Any, Optional, List
from datetime import datetime, timedelta
from pydantic import BaseModel
import logging

from database import get_db
from psycopg2.extras import RealDictCursor

logger = logging.getLogger(__name__)

router = APIRouter(prefix="/api/analytics", tags=["数据分析"])

# DB配置
DB_CONFIG = None


def set_db_config(config):
    """设置数据库配置"""
    global DB_CONFIG
    DB_CONFIG = config


# ============================================
# Response Models
# ============================================

class AnalyticsStats(BaseModel):
    """分析统计数据"""
    totalVisitors: int
    pageViews: int
    avgTimeOnPage: float
    bounceRate: float
    visitorsChange: float
    pageViewsChange: float
    timeOnPageChange: float
    bounceRateChange: float


class DateRangeData(BaseModel):
    """日期范围数据"""
    date: str
    visitors: int
    pageViews: int
    uniqueVisitors: int


class TopPage(BaseModel):
    """热门页面"""
    url: str
    title: str
    views: int
    uniqueVisitors: int
    avgTimeOnPage: float


class UserActivitySummary(BaseModel):
    """用户活动摘要"""
    totalUsers: int
    activeUsers: int
    newUsers: int
    returningUsers: int


# ============================================
# Analytics API Endpoints
# ============================================

@router.get("/overview", response_model=Dict[str, Any])
async def get_analytics_overview(
    days: int = Query(7, description="统计天数", ge=1, le=90)
):
    """
    获取分析概览数据

    返回访问量、页面浏览量、停留时间、跳出率等核心指标
    """
    try:
        with get_db(DB_CONFIG) as conn:
            with conn.cursor(cursor_factory=RealDictCursor) as cur:
                # 计算时间范围
                current_period_start = datetime.now() - timedelta(days=days)
                previous_period_start = current_period_start - timedelta(days=days)

                # 当前期间统计
                cur.execute("""
                    SELECT
                        COUNT(DISTINCT user_id) as unique_visitors,
                        COUNT(*) as total_views,
                        COUNT(DISTINCT DATE(created_at)) as active_days
                    FROM user_activity_logs
                    WHERE created_at >= %s
                """, (current_period_start,))
                current_stats = cur.fetchone()

                # 上一期间统计（用于计算变化率）
                cur.execute("""
                    SELECT
                        COUNT(DISTINCT user_id) as unique_visitors,
                        COUNT(*) as total_views
                    FROM user_activity_logs
                    WHERE created_at >= %s AND created_at < %s
                """, (previous_period_start, current_period_start))
                previous_stats = cur.fetchone()

                # 模拟平均停留时间和跳出率（实际需要更复杂的计算）
                avg_time_on_page = 272.0  # 4分32秒
                bounce_rate = 42.8

                # 计算变化率
                visitors_change = 0
                page_views_change = 0

                if previous_stats['unique_visitors'] and previous_stats['unique_visitors'] > 0:
                    visitors_change = (
                        (current_stats['unique_visitors'] - previous_stats['unique_visitors']) /
                        previous_stats['unique_visitors']
                    ) * 100

                if previous_stats['total_views'] and previous_stats['total_views'] > 0:
                    page_views_change = (
                        (current_stats['total_views'] - previous_stats['total_views']) /
                        previous_stats['total_views']
                    ) * 100

                return {
                    "success": True,
                    "data": {
                        "totalVisitors": current_stats['unique_visitors'] or 0,
                        "pageViews": current_stats['total_views'] or 0,
                        "avgTimeOnPage": avg_time_on_page,
                        "bounceRate": bounce_rate,
                        "visitorsChange": round(visitors_change, 1),
                        "pageViewsChange": round(page_views_change, 1),
                        "timeOnPageChange": 5.1,
                        "bounceRateChange": -2.3
                    }
                }
    except Exception as e:
        logger.error(f"获取分析概览失败: {str(e)}")
        return {
            "success": False,
            "message": f"获取分析概览失败: {str(e)}"
        }


@router.get("/trend", response_model=Dict[str, Any])
async def get_analytics_trend(
    days: int = Query(30, description="统计天数", ge=7, le=365)
):
    """
    获取访问趋势数据

    按日期返回访问量和页面浏览量趋势
    """
    try:
        with get_db(DB_CONFIG) as conn:
            with conn.cursor(cursor_factory=RealDictCursor) as cur:
                start_date = datetime.now() - timedelta(days=days)

                # 按日期统计访问数据
                cur.execute("""
                    SELECT
                        DATE(created_at) as date,
                        COUNT(DISTINCT user_id) as unique_visitors,
                        COUNT(*) as total_views
                    FROM user_activity_logs
                    WHERE created_at >= %s
                    GROUP BY DATE(created_at)
                    ORDER BY date ASC
                """, (start_date,))

                trend_data = []
                for row in cur.fetchall():
                    trend_data.append({
                        "date": row['date'].isoformat() if row['date'] else None,
                        "visitors": row['unique_visitors'] or 0,
                        "pageViews": row['total_views'] or 0,
                        "uniqueVisitors": row['unique_visitors'] or 0
                    })

                return {
                    "success": True,
                    "data": trend_data
                }
    except Exception as e:
        logger.error(f"获取访问趋势失败: {str(e)}")
        return {
            "success": False,
            "message": f"获取访问趋势失败: {str(e)}",
            "data": []
        }


@router.get("/top-pages", response_model=Dict[str, Any])
async def get_top_pages(
    limit: int = Query(10, description="返回数量", ge=1, le=50),
    days: int = Query(7, description="统计天数", ge=1, le=90)
):
    """
    获取热门页面

    返回访问量最高的页面列表
    """
    try:
        with get_db(DB_CONFIG) as conn:
            with conn.cursor(cursor_factory=RealDictCursor) as cur:
                start_date = datetime.now() - timedelta(days=days)

                # 统计页面访问量
                cur.execute("""
                    SELECT
                        entity,
                        COUNT(*) as views,
                        COUNT(DISTINCT user_id) as unique_visitors
                    FROM user_activity_logs
                    WHERE created_at >= %s
                      AND entity IS NOT NULL
                    GROUP BY entity
                    ORDER BY views DESC
                    LIMIT %s
                """, (start_date, limit))

                top_pages = []
                for row in cur.fetchall():
                    # 尝试从页面标题或URL获取标题
                    title = row['entity']
                    if 'skill' in row['entity'].lower():
                        title = f"Skill: {row['entity']}"

                    top_pages.append({
                        "url": f"/{row['entity'].lower()}",
                        "title": title,
                        "views": row['views'],
                        "uniqueVisitors": row['unique_visitors'],
                        "avgTimeOnPage": 120.0  # 模拟数据，实际需要计算
                    })

                return {
                    "success": True,
                    "data": top_pages
                }
    except Exception as e:
        logger.error(f"获取热门页面失败: {str(e)}")
        return {
            "success": False,
            "message": f"获取热门页面失败: {str(e)}",
            "data": []
        }


@router.get("/user-activity", response_model=Dict[str, Any])
async def get_user_activity_summary(
    days: int = Query(7, description="统计天数", ge=1, le=90)
):
    """
    获取用户活动摘要

    返回总用户数、活跃用户、新用户、回头客等数据
    """
    try:
        with get_db(DB_CONFIG) as conn:
            with conn.cursor(cursor_factory=RealDictCursor) as cur:
                start_date = datetime.now() - timedelta(days=days)

                # 总用户数
                cur.execute("""
                    SELECT COUNT(*) as count
                    FROM users
                    WHERE is_active = TRUE
                      AND email NOT LIKE '%@seed.local'
                """)
                total_users = cur.fetchone()['count']

                # 期间活跃用户
                cur.execute("""
                    SELECT COUNT(DISTINCT user_id) as count
                    FROM user_activity_logs
                    WHERE created_at >= %s
                """, (start_date,))
                active_users = cur.fetchone()['count']

                # 期间新用户
                cur.execute("""
                    SELECT COUNT(*) as count
                    FROM users
                    WHERE created_at >= %s
                      AND is_active = TRUE
                      AND email NOT LIKE '%@seed.local'
                """, (start_date,))
                new_users = cur.fetchone()['count']

                # 回头客（有历史活动记录的用户）
                cur.execute("""
                    SELECT COUNT(DISTINCT al.user_id) as count
                    FROM user_activity_logs al
                    WHERE al.created_at >= %s
                      AND al.user_id IN (
                        SELECT DISTINCT user_id
                        FROM user_activity_logs
                        WHERE created_at < %s
                      )
                """, (start_date, start_date))
                returning_users = cur.fetchone()['count']

                return {
                    "success": True,
                    "data": {
                        "totalUsers": total_users or 0,
                        "activeUsers": active_users or 0,
                        "newUsers": new_users or 0,
                        "returningUsers": returning_users or 0
                    }
                }
    except Exception as e:
        logger.error(f"获取用户活动摘要失败: {str(e)}")
        return {
            "success": False,
            "message": f"获取用户活动摘要失败: {str(e)}"
        }


@router.get("/hourly", response_model=Dict[str, Any])
async def get_hourly_stats(
    days: int = Query(7, description="统计天数", ge=1, le=30)
):
    """
    获取每小时统计数据

    返回一天24小时的访问分布
    """
    try:
        with get_db(DB_CONFIG) as conn:
            with conn.cursor(cursor_factory=RealDictCursor) as cur:
                start_date = datetime.now() - timedelta(days=days)

                # 按小时统计
                cur.execute("""
                    SELECT
                        EXTRACT(HOUR FROM created_at) as hour,
                        COUNT(*) as views,
                        COUNT(DISTINCT user_id) as unique_visitors
                    FROM user_activity_logs
                    WHERE created_at >= %s
                    GROUP BY EXTRACT(HOUR FROM created_at)
                    ORDER BY hour
                """, (start_date,))

                hourly_data = []
                for row in cur.fetchall():
                    hourly_data.append({
                        "hour": int(row['hour']),
                        "views": row['views'],
                        "uniqueVisitors": row['unique_visitors']
                    })

                # 填充缺失的小时
                complete_data = []
                for hour in range(24):
                    found = False
                    for item in hourly_data:
                        if item['hour'] == hour:
                            complete_data.append(item)
                            found = True
                            break
                    if not found:
                        complete_data.append({
                            "hour": hour,
                            "views": 0,
                            "uniqueVisitors": 0
                        })

                return {
                    "success": True,
                    "data": complete_data
                }
    except Exception as e:
        logger.error(f"获取小时统计失败: {str(e)}")
        return {
            "success": False,
            "message": f"获取小时统计失败: {str(e)}",
            "data": []
        }


@router.get("/export", response_model=Dict[str, Any])
async def export_analytics(
    start_date: str = Query(..., description="开始日期 (YYYY-MM-DD)"),
    end_date: str = Query(..., description="结束日期 (YYYY-MM-DD)"),
    format: str = Query("json", description="导出格式: json, csv")
):
    """
    导出分析数据

    支持导出为JSON或CSV格式
    """
    try:
        with get_db(DB_CONFIG) as conn:
            with conn.cursor(cursor_factory=RealDictCursor) as cur:
                # 解析日期
                start_dt = datetime.strptime(start_date, "%Y-%m-%d")
                end_dt = datetime.strptime(end_date, "%Y-%m-%d") + timedelta(days=1)

                # 获取完整数据
                cur.execute("""
                    SELECT
                        DATE(al.created_at) as date,
                        EXTRACT(HOUR FROM al.created_at) as hour,
                        al.action,
                        al.entity,
                        u.username,
                        COUNT(*) as count
                    FROM user_activity_logs al
                    LEFT JOIN users u ON al.user_id = u.id
                    WHERE al.created_at >= %s AND al.created_at < %s
                    GROUP BY DATE(al.created_at), EXTRACT(HOUR FROM al.created_at), al.action, al.entity, u.username
                    ORDER BY date, hour
                """, (start_dt, end_dt))

                data = []
                for row in cur.fetchall():
                    data.append({
                        "date": row['date'].isoformat() if row['date'] else None,
                        "hour": int(row['hour']) if row['hour'] else 0,
                        "action": row['action'],
                        "entity": row['entity'],
                        "username": row['username'],
                        "count": row['count']
                    })

                if format == "csv":
                    # 简单的CSV格式转换
                    csv_data = "date,hour,action,entity,username,count\n"
                    for item in data:
                        csv_data += f"{item['date']},{item['hour']},{item['action']},{item['entity']},{item['username']},{item['count']}\n"

                    return {
                        "success": True,
                        "data": csv_data,
                        "format": "csv"
                    }

                return {
                    "success": True,
                    "data": data,
                    "format": "json"
                }
    except Exception as e:
        logger.error(f"导出分析数据失败: {str(e)}")
        return {
            "success": False,
            "message": f"导出分析数据失败: {str(e)}"
        }
