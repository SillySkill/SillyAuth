        }
    }


# ============================================
# Creator API: 结算操作
# ============================================

@router.post("/creator/settle", response_model=dict)
async def settle_creator_earnings(
    request: SettlementRequest,
    current_user: User = Depends(get_current_user),
    db: AsyncSession = Depends(get_db)
):
    """
    结算创作者收益

    使用数据库行锁防止并发结算问题
    """
    # 验证账户类型
    if request.payment_account_type not in ALLOWED_ACCOUNT_TYPES:
        raise HTTPException(
            status_code=400,
            detail=f"无效的收款账户类型。允许的值: {', '.join(ALLOWED_ACCOUNT_TYPES)}"
        )

    # 使用事务和行锁确保原子性
    async with db.begin():
        # 检查是否有足够的待结算金额（使用 FOR UPDATE 锁定行）
        check_query = text("""
            SELECT COALESCE(SUM(creator_share), 0) AS total_pending
            FROM creator_earnings
            WHERE user_id = :user_id AND settlement_status = 'pending'
            FOR UPDATE
        """)
        result = await db.execute(check_query, {"user_id": current_user.id})
        total_pending = result.scalar()

        if total_pending < 100:
            raise HTTPException(
                status_code=400,
                detail=f"待结算金额不足 100 元，当前为 {total_pending:.2f} 元"
            )

        # 执行结算（数据库函数内部也使用 FOR UPDATE SKIP LOCKED）
        settle_query = text("""
            SELECT batch_settle_creator_earnings(
                :user_id,
                :payment_account_type,
                :payment_account_id
            ) AS settlement_id
        """)
        result = await db.execute(settle_query, {
            "user_id": current_user.id,
            "payment_account_type": request.payment_account_type,
            "payment_account_id": request.payment_account_id
        })
        settlement_id = result.scalar()

    if not settlement_id:
        raise HTTPException(status_code=500, detail="结算失败")

    logger.info(
        f"创作者收益结算成功: user_id={current_user.id}, "
        f"settlement_id={settlement_id}, amount={total_pending:.2f}"
    )

    return {
        "success": True,
        "data": {
            "settlement_id": settlement_id,
            "message": f"成功结算 {total_pending:.2f} 元"
        }
    }


@router.get("/creator/settlements", response_model=dict)
async def get_creator_settlements(
    current_user: User = Depends(get_current_user),
    page: int = Query(1, ge=1),
    page_size: int = Query(20, ge=1, le=100),
    db: AsyncSession = Depends(get_db)
):
    """
    获取创作者结算记录
    """
    # 统计总数
    count_query = text("SELECT COUNT(*) FROM settlement_records WHERE user_id = :user_id")
    result = await db.execute(count_query, {"user_id": current_user.id})
    total = result.scalar()

    # 分页查询
    offset = (page - 1) * page_size
    query = text("""
        SELECT
            id, batch_number, total_orders, total_amount, total_commission, total_earnings,
            settlement_method, status, transaction_id, failure_reason,
            period_start, period_end, created_at, processed_at
        FROM settlement_records
        WHERE user_id = :user_id
        ORDER BY created_at DESC
        LIMIT :page_size OFFSET :offset
    """)

    result = await db.execute(query, {
        "user_id": current_user.id,
        "page_size": page_size,
        "offset": offset
    })
    rows = result.fetchall()

    settlements = []
    for row in rows:
        settlements.append({
            "id": row[0],
            "batch_number": row[1],
            "total_orders": row[2],
            "total_amount": float(row[3]),
            "total_commission": float(row[4]),
            "total_earnings": float(row[5]),
            "settlement_method": row[6],
            "status": row[7],
            "transaction_id": row[8],
            "failure_reason": row[9],
            "period_start": row[10].isoformat() if row[10] else None,
            "period_end": row[11].isoformat() if row[11] else None,
            "created_at": row[12].isoformat() if row[12] else None,
            "processed_at": row[13].isoformat() if row[13] else None
        })

    return {
        "success": True,
        "data": {
            "items": settlements,
            "total": total,
            "page": page,
            "page_size": page_size,
            "total_pages": (total + page_size - 1) // page_size
        }
    }


# ============================================
# Admin API: 结算管理
# ============================================

@router.get("/admin/pending-settlements", response_model=dict)
async def get_pending_settlements(
    current_admin: User = Depends(get_current_admin),
    db: AsyncSession = Depends(get_db)
):
    """
    获取待结算创作者列表（管理员）
    """
    query = text("SELECT * FROM v_pending_settlements ORDER BY total_pending_amount DESC")
    result = await db.execute(query)
    rows = result.fetchall()

    settlements = []
    for row in rows:
        settlements.append({
            "user_id": row[0],
            "username": row[1],
            "email": row[2],
            "settlement_method": row[3],
            "payment_account_type": row[4],
            "payment_account_id": row[5],
            "min_settlement_amount": float(row[6]) if row[6] else 100,
            "pending_count": row[7],
            "total_pending_amount": float(row[8]),
            "oldest_earning_date": row[9].isoformat() if row[9] else None,
            "latest_earning_date": row[10].isoformat() if row[10] else None
        })

    return {
        "success": True,
        "data": settlements
    }


@router.post("/admin/settle/{user_id}", response_model=dict)
async def admin_settle_creator(
    user_id: int,
    request: SettlementRequest,
    current_admin: User = Depends(get_current_admin),
    db: AsyncSession = Depends(get_db)
):
    """
    管理员手动结算创作者收益

    使用数据库行锁防止并发结算问题
    """
    # 验证账户类型
    if request.payment_account_type not in ALLOWED_ACCOUNT_TYPES:
        raise HTTPException(
            status_code=400,
            detail=f"无效的收款账户类型。允许的值: {', '.join(ALLOWED_ACCOUNT_TYPES)}"
        )

    # 使用事务和行锁确保原子性
    async with db.begin():
        # 执行结算（数据库函数内部使用 FOR UPDATE SKIP LOCKED）
        settle_query = text("""
            SELECT batch_settle_creator_earnings(
                :user_id,
                :payment_account_type,
                :payment_account_id
            ) AS settlement_id
        """)
        result = await db.execute(settle_query, {
            "user_id": user_id,
            "payment_account_type": request.payment_account_type,
            "payment_account_id": request.payment_account_id
        })
        settlement_id = result.scalar()

    if not settlement_id:
        raise HTTPException(status_code=500, detail="结算失败，可能没有足够的待结算金额")

    logger.info(
        f"管理员手动结算创作者收益成功: user_id={user_id}, "
        f"settlement_id={settlement_id}, admin_id={current_admin.id}"
    )

    return {
        "success": True,
        "data": {
            "settlement_id": settlement_id,
            "user_id": user_id,
            "message": "结算成功"
        }
    }
