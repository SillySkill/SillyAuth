"""
User Settings API Routes
用户设置 API 路由

提供用户个人信息管理、偏好设置、密码修改等功能
"""
from fastapi import APIRouter, HTTPException, Depends, Query
from typing import Optional, Dict, Any
from datetime import datetime
from pydantic import BaseModel, Field, EmailStr, validator
import logging
import hashlib

from database import get_db
from psycopg2.extras import RealDictCursor

logger = logging.getLogger(__name__)

router = APIRouter(prefix="/api/user/settings", tags=["用户设置"])

# DB配置
DB_CONFIG = None


def set_db_config(config):
    """设置数据库配置"""
    global DB_CONFIG
    DB_CONFIG = config


# ============================================
# Request/Response Models
# ============================================

class UserProfileResponse(BaseModel):
    """用户资料响应"""
    id: int
    username: str
    email: str
    avatar_url: Optional[str] = None
    bio: Optional[str] = None
    role: str
    preferred_language: str
    theme_preference: str
    is_active: bool
    is_verified: bool
    created_at: datetime
    updated_at: Optional[datetime] = None


class UserProfileUpdate(BaseModel):
    """用户资料更新请求"""
    username: Optional[str] = Field(None, min_length=3, max_length=50)
    email: Optional[EmailStr] = None
    bio: Optional[str] = Field(None, max_length=500)
    avatar_url: Optional[str] = Field(None, max_length=500)


class UserPreferencesUpdate(BaseModel):
    """用户偏好设置更新请求"""
    preferred_language: Optional[str] = Field(None, pattern="^(zh-CN|en|ja|ko)$")
    theme_preference: Optional[str] = Field(None, pattern="^(tech-blue|cyber-purple|dark|light|auto)$")
    notification_enabled: Optional[bool] = None
    email_notifications: Optional[bool] = None


class PasswordChangeRequest(BaseModel):
    """密码修改请求"""
    old_password: str = Field(..., min_length=6)
    new_password: str = Field(..., min_length=8, max_length=100)

    @validator('new_password')
    def validate_password(cls, v):
        """密码强度验证"""
        if not any(c.isupper() for c in v):
            raise ValueError('密码必须包含至少一个大写字母')
        if not any(c.islower() for c in v):
            raise ValueError('密码必须包含至少一个小写字母')
        if not any(c.isdigit() for c in v):
            raise ValueError('密码必须包含至少一个数字')
        return v


# ============================================
# User Settings API Endpoints
# ============================================

@router.get("/profile", response_model=Dict[str, Any])
async def get_user_profile(
    user_id: int = Query(..., description="用户ID")
):
    """
    获取用户资料

    返回用户的基本信息和偏好设置
    """
    try:
        with get_db(DB_CONFIG) as conn:
            with conn.cursor(cursor_factory=RealDictCursor) as cur:
                cur.execute("""
                    SELECT
                        id,
                        username,
                        email,
                        avatar_url,
                        bio,
                        role,
                        preferred_language,
                        theme_preference,
                        is_active,
                        is_verified,
                        created_at,
                        updated_at
                    FROM users
                    WHERE id = %s
                """, (user_id,))

                user = cur.fetchone()

                if not user:
                    raise HTTPException(status_code=404, detail="用户不存在")

                return {
                    "success": True,
                    "data": {
                        "id": user['id'],
                        "username": user['username'],
                        "email": user['email'],
                        "avatar_url": user['avatar_url'],
                        "bio": user['bio'],
                        "role": user['role'],
                        "preferred_language": user['preferred_language'] or 'zh-CN',
                        "theme_preference": user['theme_preference'] or 'tech-blue',
                        "is_active": user['is_active'],
                        "is_verified": user['is_verified'],
                        "created_at": user['created_at'].isoformat() if user['created_at'] else None,
                        "updated_at": user['updated_at'].isoformat() if user['updated_at'] else None
                    }
                }
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"获取用户资料失败: {str(e)}")
        raise HTTPException(status_code=500, detail=f"获取用户资料失败: {str(e)}")


@router.put("/profile", response_model=Dict[str, Any])
async def update_user_profile(
    profile_data: UserProfileUpdate,
    user_id: int = Query(..., description="用户ID")
):
    """
    更新用户资料

    允许修改用户名、邮箱、简介、头像等信息
    """
    try:
        with get_db(DB_CONFIG) as conn:
            with conn.cursor(cursor_factory=RealDictCursor) as cur:
                # 构建更新数据
                update_fields = []
                params = []
                update_count = 0

                if profile_data.username is not None:
                    # 检查用户名是否已存在
                    cur.execute(
                        "SELECT id FROM users WHERE username = %s AND id != %s",
                        (profile_data.username, user_id)
                    )
                    if cur.fetchone():
                        raise HTTPException(status_code=400, detail="用户名已被使用")

                    update_fields.append("username = %s")
                    params.append(profile_data.username)
                    update_count += 1

                if profile_data.email is not None:
                    # 检查邮箱是否已存在
                    cur.execute(
                        "SELECT id FROM users WHERE email = %s AND id != %s",
                        (profile_data.email, user_id)
                    )
                    if cur.fetchone():
                        raise HTTPException(status_code=400, detail="邮箱已被使用")

                    update_fields.append("email = %s")
                    params.append(profile_data.email)
                    update_count += 1

                if profile_data.bio is not None:
                    update_fields.append("bio = %s")
                    params.append(profile_data.bio)
                    update_count += 1

                if profile_data.avatar_url is not None:
                    update_fields.append("avatar_url = %s")
                    params.append(profile_data.avatar_url)
                    update_count += 1

                if update_count == 0:
                    raise HTTPException(status_code=400, detail="没有提供更新数据")

                # 添加更新时间和用户ID
                update_fields.append("updated_at = %s")
                params.append(datetime.now())
                params.append(user_id)

                # 执行更新
                query = f"""
                    UPDATE users
                    SET {', '.join(update_fields)}
                    WHERE id = %s
                    RETURNING id, username, email, avatar_url, bio
                """

                cur.execute(query, params)
                updated_user = cur.fetchone()
                conn.commit()

                logger.info(f"用户 {user_id} 更新了资料")

                return {
                    "success": True,
                    "message": "资料更新成功",
                    "data": {
                        "id": updated_user['id'],
                        "username": updated_user['username'],
                        "email": updated_user['email'],
                        "avatar_url": updated_user['avatar_url'],
                        "bio": updated_user['bio']
                    }
                }
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"更新用户资料失败: {str(e)}")
        raise HTTPException(status_code=500, detail=f"更新用户资料失败: {str(e)}")


@router.put("/preferences", response_model=Dict[str, Any])
async def update_user_preferences(
    preferences: UserPreferencesUpdate,
    user_id: int = Query(..., description="用户ID")
):
    """
    更新用户偏好设置

    包括语言、主题、通知设置等
    """
    try:
        with get_db(DB_CONFIG) as conn:
            with conn.cursor(cursor_factory=RealDictCursor) as cur:
                # 构建更新数据
                update_fields = []
                params = []
                update_count = 0

                if preferences.preferred_language is not None:
                    update_fields.append("preferred_language = %s")
                    params.append(preferences.preferred_language)
                    update_count += 1

                if preferences.theme_preference is not None:
                    update_fields.append("theme_preference = %s")
                    params.append(preferences.theme_preference)
                    update_count += 1

                if update_count == 0:
                    raise HTTPException(status_code=400, detail="没有提供更新数据")

                # 添加更新时间和用户ID
                update_fields.append("updated_at = %s")
                params.append(datetime.now())
                params.append(user_id)

                # 执行更新
                query = f"""
                    UPDATE users
                    SET {', '.join(update_fields)}
                    WHERE id = %s
                    RETURNING id, preferred_language, theme_preference
                """

                cur.execute(query, params)
                updated_user = cur.fetchone()
                conn.commit()

                logger.info(f"用户 {user_id} 更新了偏好设置")

                return {
                    "success": True,
                    "message": "偏好设置更新成功",
                    "data": {
                        "preferred_language": updated_user['preferred_language'],
                        "theme_preference": updated_user['theme_preference']
                    }
                }
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"更新用户偏好设置失败: {str(e)}")
        raise HTTPException(status_code=500, detail=f"更新用户偏好设置失败: {str(e)}")


@router.post("/change-password", response_model=Dict[str, Any])
async def change_password(
    password_data: PasswordChangeRequest,
    user_id: int = Query(..., description="用户ID")
):
    """
    修改密码

    需要提供旧密码进行验证
    """
    try:
        with get_db(DB_CONFIG) as conn:
            with conn.cursor(cursor_factory=RealDictCursor) as cur:
                # 获取用户当前密码哈希
                cur.execute(
                    "SELECT password_hash FROM users WHERE id = %s",
                    (user_id,)
                )
                user = cur.fetchone()

                if not user:
                    raise HTTPException(status_code=404, detail="用户不存在")

                # 验证旧密码（实际应该使用bcrypt等安全哈希）
                old_password_hash = hashlib.sha256(
                    password_data.old_password.encode()
                ).hexdigest()

                if user['password_hash'] != old_password_hash:
                    raise HTTPException(status_code=400, detail="当前密码不正确")

                # 生成新密码哈希
                new_password_hash = hashlib.sha256(
                    password_data.new_password.encode()
                ).hexdigest()

                # 更新密码
                cur.execute(
                    "UPDATE users SET password_hash = %s, updated_at = %s WHERE id = %s",
                    (new_password_hash, datetime.now(), user_id)
                )
                conn.commit()

                logger.info(f"用户 {user_id} 修改了密码")

                return {
                    "success": True,
                    "message": "密码修改成功"
                }
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"修改密码失败: {str(e)}")
        raise HTTPException(status_code=500, detail=f"修改密码失败: {str(e)}")


@router.get("/settings", response_model=Dict[str, Any])
async def get_user_settings(
    user_id: int = Query(..., description="用户ID")
):
    """
    获取用户所有设置

    包括资料和偏好设置
    """
    try:
        with get_db(DB_CONFIG) as conn:
            with conn.cursor(cursor_factory=RealDictCursor) as cur:
                cur.execute("""
                    SELECT
                        id,
                        username,
                        email,
                        avatar_url,
                        bio,
                        preferred_language,
                        theme_preference
                    FROM users
                    WHERE id = %s
                """, (user_id,))

                user = cur.fetchone()

                if not user:
                    raise HTTPException(status_code=404, detail="用户不存在")

                return {
                    "success": True,
                    "data": {
                        "profile": {
                            "username": user['username'],
                            "email": user['email'],
                            "avatar_url": user['avatar_url'],
                            "bio": user['bio']
                        },
                        "preferences": {
                            "language": user['preferred_language'] or 'zh-CN',
                            "theme": user['theme_preference'] or 'tech-blue'
                        }
                    }
                }
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"获取用户设置失败: {str(e)}")
        raise HTTPException(status_code=500, detail=f"获取用户设置失败: {str(e)}")


@router.post("/upload-avatar", response_model=Dict[str, Any])
async def upload_avatar(
    user_id: int = Query(..., description="用户ID"),
    avatar_url: str = Query(..., description="头像URL")
):
    """
    上传用户头像

    实际文件上传应该通过专门的upload API，这里只接收URL
    """
    try:
        with get_db(DB_CONFIG) as conn:
            with conn.cursor(cursor_factory=RealDictCursor) as cur:
                cur.execute(
                    "UPDATE users SET avatar_url = %s, updated_at = %s WHERE id = %s RETURNING avatar_url",
                    (avatar_url, datetime.now(), user_id)
                )
                result = cur.fetchone()
                conn.commit()

                return {
                    "success": True,
                    "message": "头像上传成功",
                    "data": {
                        "avatar_url": result['avatar_url']
                    }
                }
    except Exception as e:
        logger.error(f"上传头像失败: {str(e)}")
        raise HTTPException(status_code=500, detail=f"上传头像失败: {str(e)}")
