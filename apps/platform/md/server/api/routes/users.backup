"""
Users API Routes
用户相关 API 路由

提供用户认证、个人资料管理、收藏管理等功能
"""
from fastapi import APIRouter, Depends, HTTPException, Query
from sqlalchemy.ext.asyncio import AsyncSession
from sqlalchemy import select, and_, or_, func, text, update
from typing import List, Optional
from pydantic import BaseModel, Field, validator, EmailStr
from datetime import datetime
import json
import logging

from ..database import get_db
from ..models.users import User
from ..models.tutorials import Tutorial
from ..models.downloads import Download
from ..models.orders import Order
from ..models.user_points import UserPoint
from ..models.point_transactions import PointTransaction
from ..middleware.auth import get_current_user, get_current_admin

logger = logging.getLogger(__name__)

router = APIRouter(prefix="/api/users", tags=["用户管理"])


# ============================================
# Schema Definitions
# ============================================

class UserProfileResponse(BaseModel):
    """用户资料响应"""
    id: int
    username: str
    email: str
    avatar_url: Optional[str] = None
    bio: Optional[str] = None
    role: str = "user"
    is_active: bool = True
    is_verified: bool = False
    created_at: datetime
    updated_at: Optional[datetime] = None


class UserProfileUpdate(BaseModel):
    """用户资料更新请求"""
    username: Optional[str] = Field(None, min_length=3, max_length=50)
    email: Optional[EmailStr] = None
    bio: Optional[str] = Field(None, max_length=500)
    avatar_url: Optional[str] = Field(None, max_length=500)


class UserStatsResponse(BaseModel):
    """用户统计响应"""
    total_points: int
    level: int
    experience: int


class OrderResponse(BaseModel):
    """订单响应"""
    id: int
    order_number: str
    product_name: str
    purchase_type: str
    final_price: float
    payment_status: str
    created_at: datetime


class FavoriteItemResponse(BaseModel):
    """收藏项响应"""
    id: int
    content_type: str
    content_id: int
    title: str
    thumbnail: Optional[str] = None
    category: Optional[str] = None
    price: Optional[float] = None
    created_at: datetime


class PointTransactionResponse(BaseModel):
    """积分交易响应"""
    id: int
    transaction_type: str
    transaction_source: str
    amount: int
    balance_after: int
    description: Optional[str] = None
    created_at: datetime


# ============================================
# 用户资料 API
# ============================================

@router.get("/me", response_model=dict)
async def get_current_user_profile(
    current_user: User = Depends(get_current_user),
    db: AsyncSession = Depends(get_db)
):
    """
    获取当前用户资料

    返回登录用户的基本信息
    """
    return {
        "success": True,
        "data": {
            "id": current_user.id,
            "username": current_user.username,
            "email": current_user.email,
            "avatar_url": current_user.avatar_url,
            "bio": current_user.bio,
            "role": current_user.role,
            "is_active": current_user.is_active,
            "is_verified": current_user.is_verified,
            "created_at": current_user.created_at.isoformat() if current_user.created_at else None,
            "updated_at": current_user.updated_at.isoformat() if current_user.updated_at else None
        }
    }


@router.put("/profile", response_model=dict)
async def update_user_profile(
    profile_data: UserProfileUpdate,
    current_user: User = Depends(get_current_user),
    db: AsyncSession = Depends(get_db)
):
    """
    更新用户资料

    允许修改用户名、邮箱、简介、头像等信息
    """
    # 构建更新数据
    update_data = {}
    if profile_data.username is not None:
        # 检查用户名是否已存在
        existing = await db.execute(
            select(User).where(
                and_(
                    User.username == profile_data.username,
                    User.id != current_user.id
                )
            )
        )
        if existing.scalar_one_or_none():
            raise HTTPException(status_code=400, detail="用户名已被使用")
        update_data["username"] = profile_data.username

    if profile_data.email is not None:
        # 检查邮箱是否已存在
        existing = await db.execute(
            select(User).where(
                and_(
                    User.email == profile_data.email,
                    User.id != current_user.id
                )
            )
        )
        if existing.scalar_one_or_none():
            raise HTTPException(status_code=400, detail="邮箱已被使用")
        update_data["email"] = profile_data.email

    if profile_data.bio is not None:
        update_data["bio"] = profile_data.bio

    if profile_data.avatar_url is not None:
        update_data["avatar_url"] = profile_data.avatar_url

    if not update_data:
        raise HTTPException(status_code=400, detail="没有提供更新数据")

    # 执行更新
    update_data["updated_at"] = datetime.utcnow()

    await db.execute(
        update(User)
        .where(User.id == current_user.id)
        .values(**update_data)
    )
    await db.commit()

    # 重新加载用户数据
    await db.refresh(current_user)

    logger.info(f"用户 {current_user.id} 更新了资料")

    return {
        "success": True,
        "message": "资料更新成功",
        "data": {
            "id": current_user.id,
            "username": current_user.username,
            "email": current_user.email,
            "avatar_url": current_user.avatar_url,
            "bio": current_user.bio
        }
    }


# ============================================
# 收藏管理 API
# ============================================

@router.get("/favorites", response_model=dict)
async def get_user_favorites(
    page: int = Query(1, ge=1, description="页码"),
    page_size: int = Query(20, ge=1, le=100, description="每页数量"),
    current_user: User = Depends(get_current_user),
    db: AsyncSession = Depends(get_db)
):
    """
    获取用户收藏列表

    返回用户收藏的教程和资源
    """
    # 这里假设有 favorites 表，如果没有则返回空列表
    # 实际实现需要根据数据库结构调整

    query = text("""
        SELECT
            f.id,
            f.content_type,
            f.content_id,
            COALESCE(t.title, d.name) as title,
            COALESCE(t.thumbnail_url, d.thumbnail_url) as thumbnail,
            COALESCE(t.category, d.category) as category,
            COALESCE(t.price_for_individual, d.price_for_individual) as price,
            f.created_at
        FROM favorites f
        LEFT JOIN tutorials t ON f.content_type = 'tutorial' AND f.content_id = t.id
        LEFT JOIN downloads d ON f.content_type = 'download' AND f.content_id = d.id
        WHERE f.user_id = :user_id
        ORDER BY f.created_at DESC
        LIMIT :limit OFFSET :offset
    """)

    result = await db.execute(query, {
        "user_id": current_user.id,
        "limit": page_size,
        "offset": (page - 1) * page_size
    })

    rows = result.fetchall()

    favorites = []
    for row in rows:
        favorites.append({
            "id": row[0],
            "content_type": row[1],
            "content_id": row[2],
            "title": row[3],
            "thumbnail": row[4],
            "category": row[5],
            "price": float(row[6]) if row[6] else None,
            "created_at": row[7].isoformat() if row[7] else None
        })

    return {
        "success": True,
        "data": favorites
    }


@router.post("/favorites", response_model=dict)
async def add_favorite(
    content_type: str = Query(..., description="内容类型: tutorial, download"),
    content_id: int = Query(..., description="内容ID"),
    current_user: User = Depends(get_current_user),
    db: AsyncSession = Depends(get_db)
):
    """
    添加收藏

    将指定内容添加到用户收藏列表
    """
    # 检查是否已收藏
    existing_query = text("""
        SELECT id FROM favorites
        WHERE user_id = :user_id
          AND content_type = :content_type
          AND content_id = :content_id
    """)

    result = await db.execute(existing_query, {
        "user_id": current_user.id,
        "content_type": content_type,
        "content_id": content_id
    })

    if result.fetchone():
        raise HTTPException(status_code=400, detail="已收藏")

    # 添加收藏
    insert_query = text("""
        INSERT INTO favorites (user_id, content_type, content_id, created_at)
        VALUES (:user_id, :content_type, :content_id, CURRENT_TIMESTAMP)
        RETURNING id
    """)

    result = await db.execute(insert_query, {
        "user_id": current_user.id,
        "content_type": content_type,
        "content_id": content_id
    })

    await db.commit()

    return {
        "success": True,
        "message": "收藏成功"
    }


@router.delete("/favorites/{favorite_id}", response_model=dict)
async def remove_favorite(
    favorite_id: int,
    current_user: User = Depends(get_current_user),
    db: AsyncSession = Depends(get_db)
):
    """
    取消收藏

    从用户收藏列表中移除指定内容
    """
    delete_query = text("""
        DELETE FROM favorites
        WHERE id = :favorite_id AND user_id = :user_id
        RETURNING id
    """)

    result = await db.execute(delete_query, {
        "favorite_id": favorite_id,
        "user_id": current_user.id
    })

    if not result.fetchone():
        raise HTTPException(status_code=404, detail="收藏不存在")

    await db.commit()

    return {
        "success": True,
        "message": "取消收藏成功"
    }


# ============================================
# 用户统计 API
# ============================================

@router.get("/stats", response_model=dict)
async def get_user_stats(
    current_user: User = Depends(get_current_user),
    db: AsyncSession = Depends(get_db)
):
    """
    获取用户统计信息

    返回积分、等级、经验等统计数据
    """
    # 查询用户积分信息
    query = text("""
        SELECT
            balance,
            level,
            experience
        FROM user_points
        WHERE user_id = :user_id
    """)

    result = await db.execute(query, {"user_id": current_user.id})
    row = result.fetchone()

    if not row:
        # 如果没有积分记录，创建默认记录
        insert_query = text("""
            INSERT INTO user_points (user_id, balance, level, experience)
            VALUES (:user_id, 0, 1, 0)
            RETURNING balance, level, experience
        """)
        result = await db.execute(insert_query, {"user_id": current_user.id})
        row = result.fetchone()
        await db.commit()

    return {
        "success": True,
        "data": {
            "totalPoints": row[0],
            "level": row[1],
            "experience": row[2]
        }
    }


# ============================================
# Admin API
# ============================================

@router.get("/admin/list", response_model=dict)
async def admin_list_users(
    current_admin: User = Depends(get_current_admin),
    page: int = Query(1, ge=1),
    page_size: int = Query(50, ge=1, le=100),
    search: Optional[str] = Query(None),
    role: Optional[str] = Query(None),
    db: AsyncSession = Depends(get_db)
):
    """
    获取用户列表（管理员）

    支持搜索和角色筛选
    """
    conditions = []
    params = {"limit": page_size, "offset": (page - 1) * page_size}

    query = """
        SELECT
            id, username, email, role, is_active, is_verified,
            created_at, updated_at
        FROM users
        WHERE 1=1
    """

    if search:
        conditions.append("(username LIKE :search OR email LIKE :search)")
        params["search"] = f"%{search}%"

    if role:
        conditions.append("role = :role")
        params["role"] = role

    if conditions:
        query += " AND " + " AND ".join(conditions)

    query += " ORDER BY created_at DESC LIMIT :limit OFFSET :offset"

    result = await db.execute(text(query), params)
    rows = result.fetchall()

    users = []
    for row in rows:
        users.append({
            "id": row[0],
            "username": row[1],
            "email": row[2],
            "role": row[3],
            "is_active": row[4],
            "is_verified": row[5],
            "created_at": row[6].isoformat() if row[6] else None,
            "updated_at": row[7].isoformat() if row[7] else None
        })

    return {
        "success": True,
        "data": users
    }
