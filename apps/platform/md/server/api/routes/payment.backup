@router.get("/admin/pending-submissions", response_model=dict)
async def get_pending_submissions(
    page: int = Query(1, ge=1),
    page_size: int = Query(20, ge=1, le=100),
    current_admin: User = Depends(get_current_admin),
    db: AsyncSession = Depends(get_db)
):
    """
    获取待审核的提交列表（管理员）
    """
    # 使用视图查询
    from ..database import conn
    query = """
        SELECT * FROM v_pending_submissions
        ORDER BY submitted_at DESC
        LIMIT :limit OFFSET :offset
    """

    total_query = "SELECT COUNT(*) FROM v_pending_submissions"

    total = await db.fetch_val(total_query)
    offset = (page - 1) * page_size

    rows = await db.fetch_all(query, {"limit": page_size, "offset": offset})

    return {
        "success": True,
        "data": {
            "items": [dict(row) for row in rows],
            "total": total,
            "page": page,
            "page_size": page_size,
            "total_pages": (total + page_size - 1) // page_size
        }
    }


@router.put("/admin/submissions/{submission_id}/approve", response_model=dict)
async def approve_submission(
    submission_id: int,
    current_admin: User = Depends(get_current_admin),
    db: AsyncSession = Depends(get_db)
):
    """
    人工审核通过（管理员）
    """
    submission = await db.get(UserSubmission, submission_id)
    if not submission:
        raise HTTPException(status_code=404, detail="提交记录不存在")

    # 更新状态
    submission.status = "approved"
    submission.reviewed_by = current_admin.id
    submission.reviewed_at = datetime.utcnow()

    # 自动发布内容
    await ai_moderation_service._auto_publish_submission(submission, db)

    return {
        "success": True,
        "message": "审核通过，内容已发布"
    }


@router.put("/admin/submissions/{submission_id}/reject", response_model=dict)
async def reject_submission(
    submission_id: int,
    reason: str,
    current_admin: User = Depends(get_current_admin),
    db: AsyncSession = Depends(get_db)
):
    """
    人工审核拒绝（管理员）
    """
    submission = await db.get(UserSubmission, submission_id)
    if not submission:
        raise HTTPException(status_code=404, detail="提交记录不存在")

    # 更新状态
    submission.status = "rejected"
    submission.rejection_reason = reason
    submission.reviewed_by = current_admin.id
    submission.reviewed_at = datetime.utcnow()

    await db.commit()

    return {
        "success": True,
        "message": "已拒绝该提交"
    }


@router.get("/admin/revenue/stats", response_model=dict)
async def get_revenue_stats(
    days: int = Query(30, ge=1, le=365),
    current_admin: User = Depends(get_current_admin),
    db: AsyncSession = Depends(get_db)
):
    """
    获取收入统计（管理员）
    """
    from ..database import conn

    query = """
        SELECT * FROM v_revenue_stats
        WHERE date >= CURRENT_DATE - INTERVAL ':days days'
        ORDER BY date DESC
    """

    rows = await db.fetch_all(query, {"days": days})

    # 计算汇总
    total_orders = sum(row['paid_orders'] for row in rows)
    total_revenue = sum(row['total_revenue'] for row in rows)

    return {
        "success": True,
        "data": {
            "period_days": days,
            "total_orders": total_orders,
            "total_revenue": float(total_revenue),
            "daily_stats": [dict(row) for row in rows]
        }
    }


@router.get("/admin/creator/earnings", response_model=dict)
async def get_creator_earnings(
    current_admin: User = Depends(get_current_admin),
    db: AsyncSession = Depends(get_db)
):
    """
    获取创作者收益统计（管理员）
    """
    from ..database import conn

    query = "SELECT * FROM v_creator_earnings ORDER BY total_earnings DESC"

    rows = await db.fetch_all(query)

    return {
        "success": True,
        "data": [dict(row) for row in rows]
    }
