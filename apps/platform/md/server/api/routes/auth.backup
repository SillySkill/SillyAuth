"""
Authentication API Routes
认证相关 API 路由

提供用户登录、注册、密码重置、Token 刷新等功能
"""
from fastapi import APIRouter, Depends, HTTPException, status
from pydantic import BaseModel, Field, EmailStr, validator
from typing import Optional
from datetime import datetime, timedelta
import secrets
import hashlib
import logging
import os
import re
from jose import jwt, JWTError
from pathlib import Path

from database import get_db, get_db_cursor

# 加载环境变量
from dotenv import load_dotenv
env_path = Path(__file__).parent.parent / ".env"
load_dotenv(env_path)

logger = logging.getLogger(__name__)

router = APIRouter(prefix="/api/auth", tags=["认证"])

# JWT 配置
SECRET_KEY = os.getenv("JWT_SECRET", "your-super-secret-jwt-key-change-this-in-production-2024-sillymd-api")
ALGORITHM = "HS256"
ACCESS_TOKEN_EXPIRE_MINUTES = 30 * 24 * 60  # 30 天（分钟）
REFRESH_TOKEN_EXPIRE_DAYS = 7

# 数据库配置
DB_CONFIG = {
    "host": os.getenv("DB_HOST", "localhost"),
    "port": int(os.getenv("DB_PORT", 5432)),
    "database": os.getenv("DB_NAME", "sillymd"),
    "user": os.getenv("DB_USER", "postgres"),
    "password": os.getenv("DB_PASSWORD", "")
}


# ============================================
# JWT Token Functions
# ============================================

def create_access_token(data: dict, expires_delta: timedelta = None):
    """创建访问令牌"""
    to_encode = data.copy()
    if expires_delta:
        expire = datetime.utcnow() + expires_delta
    else:
        expire = datetime.utcnow() + timedelta(minutes=ACCESS_TOKEN_EXPIRE_MINUTES)
    to_encode.update({"exp": expire, "type": "access"})
    encoded_jwt = jwt.encode(to_encode, SECRET_KEY, algorithm=ALGORITHM)
    return encoded_jwt


def create_refresh_token(data: dict):
    """创建刷新令牌"""
    to_encode = data.copy()
    expire = datetime.utcnow() + timedelta(days=REFRESH_TOKEN_EXPIRE_DAYS)
    to_encode.update({"exp": expire, "type": "refresh"})
    encoded_jwt = jwt.encode(to_encode, SECRET_KEY, algorithm=ALGORITHM)
    return encoded_jwt


# ============================================
# Schema Definitions
# ============================================

class Token(BaseModel):
    """Token 响应"""
    access_token: str
    refresh_token: str
    token_type: str = "bearer"
    expires_in: int
    user: dict

class LoginRequest(BaseModel):
    """登录请求"""
    email: str
    password: str = Field(..., min_length=1)
    remember_me: bool = False


class RegisterRequest(BaseModel):
    """注册请求"""
    username: str = Field(..., min_length=3, max_length=50)
    email: EmailStr
    password: str = Field(..., min_length=8, max_length=100)
    first_name: Optional[str] = Field(None, max_length=50)
    last_name: Optional[str] = Field(None, max_length=50)

    @validator('username')
    def username_alphanumeric(cls, v):
        if not v.replace('_', '').replace('-', '').isalnum():
            raise ValueError('用户名只能包含字母、数字、下划线和连字符')
        return v

    @validator('password')
    def password_strength(cls, v):
        """验证密码强度"""
        if len(v) < 8:
            raise ValueError('密码长度至少8位')
        if not re.search(r'[A-Z]', v):
            raise ValueError('密码必须包含至少一个大写字母')
        if not re.search(r'[a-z]', v):
            raise ValueError('密码必须包含至少一个小写字母')
        if not re.search(r'\d', v):
            raise ValueError('密码必须包含至少一个数字')
        return v


class ForgotPasswordRequest(BaseModel):
    """忘记密码请求"""
    email: str


class ResetPasswordRequest(BaseModel):
    """重置密码请求"""
    token: str = Field(..., min_length=1)
    new_password: str = Field(..., min_length=8, max_length=100)
    confirm_password: str = Field(..., min_length=8, max_length=100)

    @validator('confirm_password')
    def passwords_match(cls, v, values, **kwargs):
        if 'new_password' in values and v != values['new_password']:
            raise ValueError('两次输入的密码不一致')
        return v


class RefreshTokenRequest(BaseModel):
    """刷新 Token 请求"""
    refresh_token: str


class AuthResponse(BaseModel):
    """认证响应"""
    success: bool
    message: str
    data: Optional[dict] = None


# ============================================
# 辅助函数
# ============================================

def hash_password(password: str) -> str:
    """哈希密码（使用 SHA-256，生产环境应使用 bcrypt）"""
    # TODO: 生产环境应该使用 bcrypt 或 argon2
    return hashlib.sha256(password.encode()).hexdigest()


def generate_reset_token() -> str:
    """生成安全的重置令牌"""
    return secrets.token_urlsafe(32)


def get_user_by_email(email: str) -> Optional[dict]:
    """通过邮箱获取用户"""
    with get_db_cursor(DB_CONFIG) as cur:
        cur.execute(
            "SELECT * FROM users WHERE email = %s",
            (email,)
        )
        return cur.fetchone()


def get_user_by_username(username: str) -> Optional[dict]:
    """通过用户名获取用户"""
    with get_db_cursor(DB_CONFIG) as cur:
        cur.execute(
            "SELECT * FROM users WHERE username = %s",
            (username,)
        )
        return cur.fetchone()


def get_user_by_id(user_id: int) -> Optional[dict]:
    """通过 ID 获取用户"""
    with get_db_cursor(DB_CONFIG) as cur:
        cur.execute(
            "SELECT * FROM users WHERE id = %s",
            (user_id,)
        )
        return cur.fetchone()


# ============================================
# 认证 API 端点
# ============================================

@router.post("/login", response_model=Token, status_code=status.HTTP_200_OK)
async def login(credentials: LoginRequest):
    """
    用户登录

    验证邮箱和密码，返回访问令牌和刷新令牌
    """
    # 查找用户
    user = get_user_by_email(credentials.email)

    if not user:
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="邮箱或密码错误"
        )

    # 验证密码
    password_hash = hash_password(credentials.password)
    if user['password_hash'] != password_hash:
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="邮箱或密码错误"
        )

    # 检查账户是否激活
    if not user['is_active']:
        raise HTTPException(
            status_code=status.HTTP_403_FORBIDDEN,
            detail="账户已被禁用，请联系管理员"
        )

    # 更新最后登录时间
    with get_db_cursor(DB_CONFIG) as cur:
        cur.execute(
            "UPDATE users SET last_login_at = CURRENT_TIMESTAMP WHERE id = %s",
            (user['id'],)
        )

    # 创建令牌
    token_data = {
        "user_id": user['id'],
        "username": user['username'],
        "email": user['email'],
        "role": user.get('role', 'user')
    }

    access_token = create_access_token(token_data)
    refresh_token = create_refresh_token(token_data)

    logger.info(f"用户 {user['email']} 登录成功")

    return Token(
        access_token=access_token,
        refresh_token=refresh_token,
        token_type="bearer",
        expires_in=30 * 24 * 60,  # 30 天（分钟）
        user={
            "id": user['id'],
            "username": user['username'],
            "email": user['email'],
            "role": user.get('role', 'user'),
            "avatar_url": user.get('avatar_url'),
            "is_verified": user.get('is_verified', False)
        }
    )


@router.post("/register", response_model=Token, status_code=status.HTTP_201_CREATED)
async def register(user_data: RegisterRequest):
    """
    用户注册

    创建新账户，返回JWT token
    """
    # 检查邮箱是否已存在
    existing_email = get_user_by_email(user_data.email)
    if existing_email:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail="该邮箱已被注册"
        )

    # 检查用户名是否已存在
    existing_username = get_user_by_username(user_data.username)
    if existing_username:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail="用户名已被使用"
        )

    # 创建新用户
    password_hash = hash_password(user_data.password)

    with get_db_cursor(DB_CONFIG) as cur:
        cur.execute("""
            INSERT INTO users (username, email, password_hash, role, is_active, is_verified, created_at, updated_at)
            VALUES (%s, %s, %s, 'user', TRUE, FALSE, CURRENT_TIMESTAMP, CURRENT_TIMESTAMP)
            RETURNING id, username, email, role, is_verified, avatar_url
        """, (user_data.username, user_data.email, password_hash))
        new_user = cur.fetchone()

    logger.info(f"新用户 {new_user['email']} 注册成功")

    # 生成JWT token
    token_data = {
        "user_id": new_user['id'],
        "username": new_user['username'],
        "email": new_user['email'],
        "role": new_user.get('role', 'user')
    }

    access_token = create_access_token(token_data)
    refresh_token = create_refresh_token(token_data)

    return Token(
        access_token=access_token,
        refresh_token=refresh_token,
        token_type="bearer",
        expires_in=30 * 24 * 60,  # 30 天（分钟）
        user={
            "id": new_user['id'],
            "username": new_user['username'],
            "email": new_user['email'],
            "role": new_user.get('role', 'user'),
            "avatar_url": new_user.get('avatar_url'),
            "is_verified": new_user.get('is_verified', False)
        }
    )


@router.post("/forgot-password", response_model=AuthResponse)
async def forgot_password(request: ForgotPasswordRequest):
    """
    忘记密码

    发送密码重置邮件（包含安全的重置token）
    """
    # 查找用户
    user = get_user_by_email(request.email)

    if not user:
        # 为了安全，即使用户不存在也返回成功消息
        # 防止邮箱枚举攻击
        logger.warning(f"尝试对不存在的邮箱进行密码重置: {request.email}")
        return AuthResponse(
            success=True,
            message="如果该邮箱存在，重置链接已发送"
        )

    # 生成安全的重置令牌（32字节随机字符串）
    reset_token = generate_reset_token()
    expires_at = datetime.now() + timedelta(hours=1)  # 1 小时后过期

    # 保存重置令牌到数据库
    with get_db_cursor(DB_CONFIG) as cur:
        cur.execute("""
            INSERT INTO password_reset_tokens (user_id, token, expires_at, created_at)
            VALUES (%s, %s, %s, CURRENT_TIMESTAMP)
        """, (user['id'], reset_token, expires_at))

    # TODO: 集成邮件服务发送重置链接
    # reset_link = f"https://yourdomain.com/reset-password?token={reset_token}"
    # send_email(user.email, "Reset Your Password", reset_link)

    # 开发环境：记录日志
    logger.info(f"密码重置令牌已生成（用户 {user['email']}）: {reset_token}")

    return AuthResponse(
        success=True,
        message="如果该邮箱存在，重置链接已发送到您的邮箱，链接 1 小时内有效"
    )


@router.post("/reset-password", response_model=AuthResponse)
async def reset_password(request: ResetPasswordRequest):
    """
    重置密码

    使用重置令牌设置新密码
    """
    # 验证令牌
    with get_db_cursor(DB_CONFIG) as cur:
        cur.execute("""
            SELECT
                prt.id,
                prt.user_id,
                prt.expires_at,
                prt.used_at
            FROM password_reset_tokens prt
            WHERE prt.token = %s
              AND prt.used_at IS NULL
              AND prt.expires_at > CURRENT_TIMESTAMP
            ORDER BY prt.created_at DESC
            LIMIT 1
        """, (request.token,))
        token_record = cur.fetchone()

    if not token_record:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail="重置链接无效或已过期"
        )

    token_id, user_id, expires_at, used_at = token_record

    # 获取用户
    user = get_user_by_id(user_id)
    if not user:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail="用户不存在"
        )

    # 更新密码
    new_password_hash = hash_password(request.new_password)

    with get_db_cursor(DB_CONFIG) as cur:
        # 更新密码
        cur.execute("""
            UPDATE users
            SET password_hash = %s, updated_at = CURRENT_TIMESTAMP
            WHERE id = %s
        """, (new_password_hash, user_id))

        # 标记令牌已使用
        cur.execute("""
            UPDATE password_reset_tokens
            SET used_at = CURRENT_TIMESTAMP
            WHERE id = %s
        """, (token_id,))

    logger.info(f"用户 {user['email']} 重置密码成功")

    return AuthResponse(
        success=True,
        message="密码重置成功，请使用新密码登录"
    )


@router.post("/refresh-token", response_model=Token)
async def refresh_token(request: RefreshTokenRequest):
    """
    刷新访问令牌

    使用刷新令牌获取新的访问令牌
    """
    try:
        # 解码刷新令牌
        payload = jwt.decode(
            request.refresh_token,
            SECRET_KEY,
            algorithms=[ALGORITHM]
        )

        # 检查令牌类型
        if payload.get("type") != "refresh":
            raise HTTPException(
                status_code=status.HTTP_401_UNAUTHORIZED,
                detail="无效的令牌类型"
            )

        user_id = payload.get("user_id")
        if not user_id:
            raise HTTPException(
                status_code=status.HTTP_401_UNAUTHORIZED,
                detail="令牌无效"
            )

        # 获取用户
        user = get_user_by_id(user_id)
        if not user or not user['is_active']:
            raise HTTPException(
                status_code=status.HTTP_401_UNAUTHORIZED,
                detail="用户不存在或已被禁用"
            )

        # 创建新令牌
        token_data = {
            "user_id": user['id'],
            "username": user['username'],
            "email": user['email'],
            "role": user.get('role', 'user')
        }

        access_token = create_access_token(token_data)
        new_refresh_token = create_refresh_token(token_data)

        return Token(
            access_token=access_token,
            refresh_token=new_refresh_token,
            token_type="bearer",
            expires_in=30 * 24 * 60,
            user={
                "id": user['id'],
                "username": user['username'],
                "email": user['email'],
                "role": user.get('role', 'user'),
                "avatar_url": user.get('avatar_url'),
                "is_verified": user.get('is_verified', False)
            }
        )

    except JWTError as e:
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="令牌无效或已过期"
        )


@router.post("/verify-email/{token}", response_model=AuthResponse)
async def verify_email(token: str):
    """
    验证邮箱

    使用验证令牌验证用户邮箱
    """
    # 查找验证记录
    with get_db_cursor(DB_CONFIG) as cur:
        cur.execute("""
            SELECT
                ev.id,
                ev.user_id,
                ev.email,
                ev.expires_at,
                ev.verified_at
            FROM email_verifications ev
            WHERE ev.token = %s
              AND ev.verified_at IS NULL
              AND ev.expires_at > CURRENT_TIMESTAMP
            ORDER BY ev.created_at DESC
            LIMIT 1
        """, (token,))
        verification = cur.fetchone()

    if not verification:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail="验证链接无效或已过期"
        )

    verification_id, user_id, email, expires_at, verified_at = verification

    with get_db_cursor(DB_CONFIG) as cur:
        # 标记为已验证
        cur.execute("""
            UPDATE email_verifications
            SET verified_at = CURRENT_TIMESTAMP
            WHERE id = %s
        """, (verification_id,))

        # 更新用户验证状态
        cur.execute("""
            UPDATE users
            SET is_verified = TRUE
            WHERE id = %s
        """, (user_id,))

    logger.info(f"用户 {email} 邮箱验证成功")

    return AuthResponse(
        success=True,
        message="邮箱验证成功"
    )


@router.post("/logout", response_model=AuthResponse)
async def logout():
    """
    用户登出

    客户端应删除存储的令牌
    """
    # JWT 是无状态的，登出主要在客户端处理
    # 可选：实现令牌黑名单
    return AuthResponse(
        success=True,
        message="登出成功"
    )
