# Server Configuration
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# Database
DATABASE_URL="mysql://root:password@localhost:3306/sillymd_cms"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# CORS
CORS_ORIGIN=http://localhost:3000

# WebSocket CORS (逗号分隔的允许来源)
WS_CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://sillymd.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# PayPal Configuration
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=your_webhook_id_here
FRONTEND_URL=http://localhost:3000

# ============================================
# 微信支付配置 (WeChat Pay V2)
# ============================================
# 商户号 (从微信商户平台获取)
WECHAT_MCH_ID=your_wechat_mch_id

# 微信支付 APPID (从微信公众平台获取)
WECHAT_APPID=your_wechat_appid

# APIv2 密钥 (从微信商户平台获取)
WECHAT_API_KEY=your_wechat_api_v2_key

# 微信支付回调地址 (必须是 HTTPS)
WECHAT_NOTIFY_URL=https://sillymd.com/api/v1/store/callback/wechat

# ============================================
# 支付宝配置 (Alipay)
# ============================================
# 支付宝应用ID (从支付宝开放平台获取)
ALIPAY_APP_ID=your_alipay_app_id

# 支付宝私钥 (RSA2)
ALIPAY_PRIVATE_KEY=your_alipay_private_key

# 支付宝公钥 (RSA2)
ALIPAY_PUBLIC_KEY=your_alipay_public_key

# 支付宝回调地址 (必须是 HTTPS)
ALIPAY_NOTIFY_URL=https://sillymd.com/api/v1/store/callback/alipay

# WeChat Pay Configuration (微信支付)
WECHAT_APPID=your_wechat_appid_here
WECHAT_MCH_ID=your_merchant_id_here
WECHAT_API_KEY=your_api_v2_key_here
WECHAT_NOTIFY_URL=https://sillymd.com/api/v1/store/callback/wechat

# Alipay Configuration (支付宝)
ALIPAY_APP_ID=your_alipay_app_id_here
ALIPAY_PRIVATE_KEY=your_private_key_here
ALIPAY_PUBLIC_KEY=alipay_public_key_here
ALIPAY_NOTIFY_URL=https://sillymd.com/api/v1/store/callback/alipay
