{
  "name": "sillymd-seed-generator",
  "version": "1.1.0",
  "description": "SillyMD 首期种子数据生成系统 - 真实版",
  "main": "seed-generator.js",
  "scripts": {
    "generate": "node seed-generator.js",
    "generate:small": "node seed-generator.js --users 20 --skills 50",
    "generate:medium": "node seed-generator.js --users 50 --skills 200",
    "generate:large": "node seed-generator.js --users 100 --skills 500",
    "generate:xlarge": "node seed-generator.js --users 200 --skills 1000",
    "test": "node seed-generator.js --users 10 --skills 20 --output ./test",
