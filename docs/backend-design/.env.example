# ============================================
# SillyMD Backend - .env.example
# ============================================

# Environment
ENVIRONMENT=development
DEBUG=True

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sillymd

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CLUSTER_MODE=False

# Security
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI/ML
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
AI_REVIEW_MODEL=gpt-4o-mini

# Search
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=masterKey

# OSS (Optional)
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=
OSS_ENDPOINT=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Crawler
CRAWLER_ENABLED=True
CRAWLER_MAX_DAILY_IMPORTS=50
REVIEW_DIFFICULTY=medium

# Transaction
PLATFORM_FEE_RATE=0.15
MIN_WITHDRAWAL=500
POINTS_EXCHANGE_RATE=10

# Tracing
ENABLE_TRACING=False
JAEGER_HOST=localhost
JAEGER_PORT=6831
